DATABASE_URL=postgres://postgres:password@localhost:5432/aminah_jaya

# SSH Tunnel Configuration (Disabled for local dev usually)
USE_SSH_TUNNEL=false
SSH_HOST=your-remote-host.com
SSH_USER=ubuntu
SSH_KEY_PATH=/path/to/your/private_key
DB_REMOTE_HOST=127.0.0.1
DB_REMOTE_PORT=5432
DB_LOCAL_PORT=5440

JWT_SECRET=your_jwt_secret_key_here
PORT=8001
RUST_LOG=debug

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASS=password

# Cloudflare R2 Storage (Local/Dev Bucket)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET=aminah-jaya-dev
R2_PUBLIC_URL=https://dev-cdn.example.com
