DATABASE_URL=postgres://prod_user:prod_password@db.aminahjaya.com:5432/aminah_jaya_prod

# SSH Tunnel Configuration
# Set to true if the production database is only accessible via SSH bastion
USE_SSH_TUNNEL=false
SSH_HOST=bastion.aminahjaya.com
SSH_USER=deploy
SSH_KEY_PATH=/home/deploy/.ssh/id_rsa
DB_REMOTE_HOST=db.internal.aminahjaya.com
DB_REMOTE_PORT=5432
DB_LOCAL_PORT=5440

JWT_SECRET=change_this_to_a_long_random_string_in_production
PORT=8080
RUST_LOG=info

MONGO_HOST=mongo.internal.aminahjaya.com
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASS=secure_password

# Cloudflare R2 Storage (Production Bucket)
R2_ACCOUNT_ID=your_prod_account_id
R2_ACCESS_KEY=your_prod_access_key
R2_SECRET_KEY=your_prod_secret_key
R2_BUCKET=aminah-jaya-prod
R2_PUBLIC_URL=https://cdn.aminahjaya.com
