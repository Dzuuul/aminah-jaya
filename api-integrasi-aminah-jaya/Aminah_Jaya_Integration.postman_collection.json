			"type": "string"
		},
		{
			"key": "phone_number_id",
			"value": "your_phone_number_id",
			"type": "string"
		},
		{
			"key": "customer_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "merchant_order_id",
			"value": "ORD-TEST-001",
			"type": "string"
		},
		{
			"key": "draft_order_id",
			"value": "draft_order_id_dari_biteship",
			"type": "string"
		},
		{
			"key": "biteship_order_id",
			"value": "biteship_order_id",
			"type": "string"
		},
		{
			"key": "tracking_id",
			"value": "tracking_id",
			"type": "string"
		},
		{
			"key": "duitku_merchant_code",
			"value": "your_merchant_code",
			"type": "string"
		}
	]
}
