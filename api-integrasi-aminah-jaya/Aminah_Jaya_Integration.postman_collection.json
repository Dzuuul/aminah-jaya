	"item": [
		{
			"name": "Webhook",
			"item": [
				{
					"name": "Verify Webhook",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/webhook?hub.mode=subscribe&hub.verify_token={{verify_token}}&hub.challenge=123456",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"webhook"
							],
							"query": [
								{
									"key": "hub.mode",
									"value": "subscribe"
								},
								{
									"key": "hub.verify_token",
									"value": "{{verify_token}}"
								},
								{
									"key": "hub.challenge",
									"value": "123456"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Handle Webhook",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"object\": \"whatsapp_business_account\",\n    \"entry\": [\n        {\n            \"id\": \"123456789\",\n            \"changes\": [\n                {\n                    \"value\": {\n                        \"messaging_product\": \"whatsapp\",\n                        \"metadata\": {\n                            \"display_phone_number\": \"123456789\",\n                            \"phone_number_id\": \"123456789\"\n                        },\n                        \"contacts\": [\n                            {\n                                \"profile\": {\n                                    \"name\": \"Customer Name\"\n                                },\n                                \"wa_id\": \"628123456789\"\n                            }\n                        ],\n                        \"messages\": [\n                            {\n                                \"from\": \"628123456789\",\n                                \"id\": \"msg-123\",\n                                \"timestamp\": \"1625000000\",\n                                \"text\": {\n                                    \"body\": \"Halo Aminah Jaya\"\n                                },\n                                \"type\": \"text\"\n                            }\n                        ]\n                    },\n                    \"field\": \"messages\"\n                }\n            ]\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/webhook",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"webhook"
							]
						}
					},
					"response": []
				}
			]
		}
